              "operator": { "type": "boolean", "operation": "equals" }
            }
          ]
        }
      },
      "id": "node-check-handoff",
      "name": "Handoff para humano?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1340, 460]
    },
    {
      "parameters": {
        "url": "https://graph.facebook.com/v19.0/me/messages",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [{ "name": "access_token", "value": "={{ $env.META_PAGE_ACCESS_TOKEN }}" }]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={\n  \"recipient\": { \"id\": \"{{ $('Extrai mensagem').item.json.external_user_id }}\" },\n  \"message\": { \"text\": \"{{ $('Chama Backend Python').item.json.reply }}\" }\n}",
        "options": {}
      },
      "id": "node-send-reply",
      "name": "Envia resposta ao Messenger",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1560, 380]
    },
    {
      "parameters": {
        "url": "https://graph.facebook.com/v19.0/me/messages",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [{ "name": "access_token", "value": "={{ $env.META_PAGE_ACCESS_TOKEN }}" }]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={\n  \"recipient\": { \"id\": \"{{ $('Extrai mensagem').item.json.external_user_id }}\" },\n  \"message\": { \"text\": \"{{ $('Chama Backend Python').item.json.reply }}\\n\\n⚠️ Um agente humano irá continuar seu atendimento em breve.\" }\n}",
        "options": {}
      },
      "id": "node-send-handoff-msg",
      "name": "Envia msg de handoff",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1560, 560]
    },
    {
      "parameters": {
        "jsCode": "// Aqui você pode integrar com seu sistema de tickets:\n// Zendesk, Freshdesk, Slack, email, etc.\n// Por enquanto loga o handoff.\nconst data = $input.first().json;\nconsole.log('HANDOFF TRIGGERED', {\n  conversation_id: data.conversation_id,\n  urgency_score: data.urgency_score,\n  intent: data.intent\n});\nreturn $input.all();"
      },
      "id": "node-notify-team",
      "name": "Notifica equipe (Slack/Email)",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1780, 560]
    },
    {
      "parameters": {
        "jsCode": "// Log estruturado de cada interação\nconst data = $input.first().json;\nconsole.log(JSON.stringify({\n  event: 'messenger_message_processed',\n  conversation_id: data.conversation_id,\n  intent: data.intent,\n  urgency_score: data.urgency_score,\n  tokens_used: data.tokens_used,\n  human_handoff: data.human_handoff,\n  ts: new Date().toISOString()\n}));\nreturn $input.all();"
      },
      "id": "node-log",
      "name": "Log de auditoria",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1780, 380]
    }
