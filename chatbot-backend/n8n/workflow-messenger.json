    {
      "parameters": {
        "httpMethod": "POST",
        "path": "messenger",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "node-webhook-message",
      "name": "Webhook — Mensagem recebida",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 520],
      "webhookId": "messenger-webhook"
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "EVENT_RECEIVED",
        "options": { "responseCode": 200 }
      },
      "id": "node-respond-ok",
      "name": "Responde 200 ao Meta",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [460, 520]
    },
    {
      "parameters": {
        "jsCode": "// Extrai a primeira mensagem do payload do Messenger\nconst body = $input.first().json.body;\nconst entry = body.entry?.[0];\nconst messaging = entry?.messaging?.[0];\n\nif (!messaging || !messaging.message?.text) {\n  // Ignora eventos sem texto (ex: read, delivery)\n  return [];\n}\n\nconst senderId = messaging.sender.id;\nconst text = messaging.message.text;\nconst timestamp = messaging.timestamp;\n\nreturn [{\n  json: {\n    external_user_id: senderId,\n    channel: 'messenger',\n    text: text,\n    timestamp: timestamp,\n    raw_payload: messaging\n  }\n}];"
      },
      "id": "node-extract-message",
      "name": "Extrai mensagem",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 520]
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "leftValue": "={{ $json.text }}",
              "rightValue": "",
              "operator": { "type": "string", "operation": "notEmpty" }
            }
          ]
        }
      },
      "id": "node-has-text",
      "name": "Tem texto?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [900, 520]
    },
    {
      "parameters": {
        "url": "http://api:8000/api/v1/messages/incoming",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Webhook-Secret",
              "value": "={{ $env.N8N_WEBHOOK_SECRET }}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "external_user_id", "value": "={{ $json.external_user_id }}" },
            { "name": "channel", "value": "messenger" },
            { "name": "text", "value": "={{ $json.text }}" }
          ]
        },
        "options": { "timeout": 15000 }
      },
      "id": "node-call-backend",
      "name": "Chama Backend Python",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1120, 460]
