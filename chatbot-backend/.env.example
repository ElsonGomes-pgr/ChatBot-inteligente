# ── App ────────────────────────────────────────────
APP_NAME=Chatbot API
DEBUG=true
ENVIRONMENT=development
SECRET_KEY=dev_secret_key_change_in_production

# ── Database ───────────────────────────────────────
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=chatbot_secret
POSTGRES_DB=chatbot_db
DATABASE_URL=postgresql+asyncpg://chatbot:chatbot_secret@postgres:5432/chatbot_db

# ── Redis ──────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── IA Provider (anthropic ou openai) ──────────────
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── n8n ────────────────────────────────────────────
N8N_WEBHOOK_SECRET=webhook_secret_change_me
N8N_CALLBACK_URL=http://n8n:5678/webhook/agent-reply
N8N_USER=admin
N8N_PASSWORD=admin_secret_change_me

# ── Session / Timeout ─────────────────────────────
SESSION_TTL_SECONDS=1800
HUMAN_HANDOFF_URGENCY_THRESHOLD=0.75
CONVERSATION_TIMEOUT_MINUTES=30

# ── Slack (opcional) ───────────────────────────────
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_HANDOFF_CHANNEL=

# ── WhatsApp Cloud API ─────────────────────────────
WHATSAPP_ACCESS_TOKEN=
META_VERIFY_TOKEN=

# ── Segurança ──────────────────────────────────────
API_KEY=gere_uma_chave_forte_aqui
RATE_LIMIT_PER_MINUTE=60
META_APP_SECRET=

# ── Uvicorn ────────────────────────────────────────
UVICORN_WORKERS=2

# ── URL pública ────────────────────────────────────
APP_BASE_URL=http://localhost:8000
